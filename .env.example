# ============================================================
# VARIÁVEIS DE AMBIENTE — Absolluto Design²
# Copie este arquivo para .env e preencha os valores
# No Railway: adicione estas variáveis em Settings > Variables
# ============================================================

# ── OBRIGATÓRIAS ──────────────────────────────────────────────

# Banco de dados MySQL (copie do serviço MySQL do Railway)
DATABASE_URL=mysql://usuario:senha@host:3306/banco

# Chave secreta para JWT (pode ser qualquer texto longo e aleatório)
JWT_SECRET=minha-chave-super-secreta-absolluto-2024

# Ambiente
NODE_ENV=production

# ── EMAIL (para receber os briefings) ────────────────────────

# Seu Gmail
EMAIL_USER=absollutodesign@gmail.com

# App Password do Gmail (16 caracteres SEM espaços)
# Como gerar: myaccount.google.com > Segurança > Verificação em 2 etapas > Senhas de app
EMAIL_PASSWORD=abcdabcdabcdabcd

# Email para receber as notificações (opcional, padrão = EMAIL_USER)
# EMAIL_TO=absollutodesign@gmail.com

# ── OPCIONAIS ─────────────────────────────────────────────────

# URL do site (para links nos emails)
SITE_URL=https://www.absollutodesign.com.br
